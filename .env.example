# Provider API keys. Set one for the provider you use.
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
OPENROUTER_API_KEY=

# Optional web-search providers.
TAVILY_API_KEY=
BRAVE_API_KEY=

# Deploy phase. Required only when deploying to Vercel.
VERCEL_TOKEN=

# Optional Pilot Agent config overrides.
PILOT_AGENT_PROVIDER=anthropic
PILOT_AGENT_MODEL=claude-sonnet-4-6
PILOT_AGENT_API_KEY_ENV=ANTHROPIC_API_KEY
PILOT_AGENT_BACKEND=docker
PILOT_AGENT_SANDBOX_IMAGE=pilot-agent-sandbox:latest
PILOT_AGENT_SANDBOX_NETWORK=bridge
PILOT_AGENT_BUDGET_RATIO=0.7
PILOT_AGENT_MAX_TURNS=200
PILOT_AGENT_TOOL_TIMEOUT_S=120
PILOT_AGENT_PHASES_DEPLOY_ENABLED=true
PILOT_AGENT_PHASES_MARKETING_ENABLED=true
PILOT_AGENT_TOOLS_WEB_SEARCH_ENABLED=true
PILOT_AGENT_TOOLS_WEB_SEARCH_PROVIDER=tavily
PILOT_AGENT_TOOLS_WEB_SEARCH_MAX_RESULTS=5
PILOT_AGENT_TOOLS_WEB_FETCH_ENABLED=false
PILOT_AGENT_TOOLS_DEPLOY_ENABLED=true
PILOT_AGENT_UI_COLOR=auto
PILOT_AGENT_UI_SHOW_TOKEN_COUNTER=true
