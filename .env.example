# Provider API keys. Set one for the provider you use.
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
OPENROUTER_API_KEY=

# Optional web-search providers.
TAVILY_API_KEY=
BRAVE_API_KEY=

# Deploy phase. Required only when deploying to Vercel.
VERCEL_TOKEN=

# Optional DevAgent config overrides.
DEVAGENT_PROVIDER=anthropic
DEVAGENT_MODEL=claude-sonnet-4-6
DEVAGENT_API_KEY_ENV=ANTHROPIC_API_KEY
DEVAGENT_BACKEND=docker
DEVAGENT_SANDBOX_IMAGE=devagent-sandbox:latest
DEVAGENT_SANDBOX_NETWORK=bridge
DEVAGENT_BUDGET_RATIO=0.7
DEVAGENT_MAX_TURNS=200
DEVAGENT_TOOL_TIMEOUT_S=120
DEVAGENT_PHASES_DEPLOY_ENABLED=true
DEVAGENT_PHASES_MARKETING_ENABLED=true
DEVAGENT_TOOLS_WEB_SEARCH_ENABLED=true
DEVAGENT_TOOLS_WEB_SEARCH_PROVIDER=tavily
DEVAGENT_TOOLS_WEB_SEARCH_MAX_RESULTS=5
DEVAGENT_TOOLS_WEB_FETCH_ENABLED=false
DEVAGENT_TOOLS_DEPLOY_ENABLED=true
DEVAGENT_UI_COLOR=auto
DEVAGENT_UI_SHOW_TOKEN_COUNTER=true
